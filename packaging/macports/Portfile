PortSystem          1.0
PortGroup           python 1.0

name                mackup
version             0.10.2
revision            0

categories-prepend  sysutils
platforms           {darwin any}
supported_archs     noarch
license             GPL-3+
maintainers         {@eejd github.com/eejd} openmaintainer

description         Keep your application settings in sync.

long_description    Mackup backs up your application settings in a safe \
                    directory (e.g. Dropbox, iCloud), so they can then be \
                    synced across all your machines, and restored with a \
                    single command. This build is from a development fork \
                    with native sync detection support.

homepage            https://github.com/eejd/mackup

# master_sites uses a local distfile generated via:
#   git archive --prefix=mackup-${version}/ --format=tar.gz HEAD \
#       -o /opt/macports-ports-local/sysutils/mackup/files/mackup-${version}.tar.gz
# Checksums must be updated after regenerating the tarball.
master_sites        file:///opt/macports-ports-local/sysutils/mackup/files/
distname            mackup-${version}
extract.suffix      .tar.gz

checksums           rmd160  944dafd036a3301dd9e919c44daca9d3215fd3a2 \
                    sha256  4fc77bd3a0a25d4286ca2a4caf3ecfe42717ea661be8c3631167c446a4368621 \
                    size    172424

python.default_version 313
python.pep517_backend  hatch

depends_lib-append \
                    port:py${python.version}-docopt-ng

livecheck.type      none
